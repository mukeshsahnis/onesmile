---
import Layout from '../../layouts/Layout.astro';
import { getCollection, getEntry, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(entry => ({
    params: { id: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

// Fetch related services details
const relatedServices = await Promise.all(
  (entry.data.relatedServices || []).map(async (relatedId) => {
    return await getEntry('services', relatedId);
  })
).then(results => results.filter(Boolean));

// Dynamic BlogPosting Schema Markup for SEO
const blogSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": entry.data.title,
  "description": entry.data.description,
  "image": entry.data.heroImage ? new URL(entry.data.heroImage, Astro.url.origin).toString() : undefined,
  "datePublished": entry.data.pubDate.toISOString(),
  "dateModified": entry.data.updatedDate ? entry.data.updatedDate.toISOString() : entry.data.pubDate.toISOString(),
  "author": {
    "@type": "Person",
    "name": entry.data.author,
    "jobTitle": "Dentist"
  },
  "publisher": {
    "@type": "Organization",
    "name": "One Smile Dental Care",
    "logo": {
      "@type": "ImageObject",
      "url": "https://onesmiledentalcare.com/logos/logo.png"
    }
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": Astro.url.href
  }
};
---

<Layout 
  title={`${entry.data.title} | One Smile Dental Care Blog`}
  description={entry.data.description}
  image={entry.data.heroImage}
>
  {/* Inject Blog Schema */}
  <script type="application/ld+json" set:html={JSON.stringify(blogSchema)} />

  <article class="bg-stone-50 min-h-screen">
    {/* Page Header */}
    <header class="py-16 bg-stone-900 text-white relative overflow-hidden">
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,_var(--tw-gradient-stops))] from-teal-950/30 via-stone-950 to-stone-950 opacity-90 z-0"></div>
      <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <a href={`${import.meta.env.BASE_URL}blog`} class="inline-flex items-center gap-2 text-sm text-teal-400 hover:text-teal-300 font-semibold mb-6 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
          </svg>
          Back to Blog
        </a>
        <div class="flex items-center gap-4 text-xs font-semibold text-teal-400 uppercase tracking-widest mb-3">
          <span>{entry.data.category}</span>
          <span>•</span>
          <span>{new Date(entry.data.pubDate).toLocaleDateString(undefined, {month: 'short', day: 'numeric', year: 'numeric'})}</span>
        </div>
        <h1 class="text-3xl sm:text-5xl font-extrabold tracking-tight mb-6 leading-tight">{entry.data.title}</h1>
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 rounded-full bg-teal-100 text-teal-700 flex items-center justify-center font-bold text-sm">
            {entry.data.author.charAt(0)}
          </div>
          <div class="flex flex-col">
            <span class="text-sm font-bold text-stone-100">By {entry.data.author}</span>
            <span class="text-xs text-stone-400">Clinical Expert & Author</span>
          </div>
        </div>
      </div>
    </header>

    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
        
        {/* Main Content */}
        <div class="lg:col-span-8 flex flex-col gap-8">
          
          {/* Main Visual Anchor */}
          {entry.data.heroImage && (
            <div class="aspect-video w-full rounded-2xl overflow-hidden bg-stone-200 shadow-md border border-stone-200">
              <img 
                src={entry.data.heroImage.startsWith('/') ? `${import.meta.env.BASE_URL}${entry.data.heroImage.slice(1)}` : entry.data.heroImage} 
                alt={entry.data.title} 
                class="w-full h-full object-cover"
              />
            </div>
          )}

          {/* Rendered Article */}
          <div class="prose prose-stone max-w-none prose-headings:text-stone-900 prose-p:text-stone-700 prose-strong:text-stone-900 leading-relaxed">
            <Content />
          </div>

          {/* Tags */}
          {entry.data.tags && entry.data.tags.length > 0 && (
            <div class="border-t border-stone-250 pt-6 flex flex-wrap gap-2">
              {entry.data.tags.map(tag => (
                <span class="text-xs font-semibold bg-stone-200 text-stone-700 px-3 py-1 rounded-full">
                  #{tag}
                </span>
              ))}
            </div>
          )}

        </div>

        {/* Sidebar */}
        <div class="lg:col-span-4 flex flex-col gap-8">
          
          {/* Related Services Links */}
          {relatedServices.length > 0 && (
            <div class="bg-white border border-stone-200 rounded-2xl p-6 shadow-sm">
              <h3 class="font-bold text-stone-900 text-base mb-4 border-b border-stone-100 pb-2">Related Treatments</h3>
              <div class="flex flex-col gap-4">
                {relatedServices.map(relService => (
                  <a href={`${import.meta.env.BASE_URL}services/${relService.id}`} class="group flex items-center gap-3 focus:outline-none">
                    <div class="w-12 h-12 rounded-lg overflow-hidden bg-stone-100 shrink-0">
                      <img 
                        src={relService.data.image.startsWith('/') ? `${import.meta.env.BASE_URL}${relService.data.image.slice(1)}` : relService.data.image} 
                        alt={relService.data.title} 
                        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                      />
                    </div>
                    <div class="flex flex-col">
                      <h4 class="text-sm font-bold text-stone-900 group-hover:text-teal-600 transition-colors leading-tight">
                        {relService.data.title}
                      </h4>
                      <span class="text-xs text-stone-500 line-clamp-1 mt-0.5">
                        {relService.data.summary}
                      </span>
                    </div>
                  </a>
                ))}
              </div>
            </div>
          )}

          {/* Booking Promo */}
          <div class="bg-teal-900 text-white rounded-2xl p-6 shadow-sm flex flex-col gap-4">
            <h3 class="font-bold text-teal-300 text-sm uppercase tracking-wider">Concerned about your smile?</h3>
            <p class="text-xs text-stone-200 leading-relaxed">
              Schedule a personalized consultation with Dr. Radhika to discuss your treatment options.
            </p>
            <a 
              href="https://wa.me/918400021200" 
              target="_blank" 
              rel="noopener noreferrer" 
              class="btn btn-primary text-white w-full text-center"
            >
              Book via WhatsApp
            </a>
          </div>

        </div>

      </div>
    </div>
  </article>
</Layout>
