---
import Layout from '../../layouts/Layout.astro';
import { getCollection, getEntry, render } from 'astro:content';

export async function getStaticPaths() {
  const services = await getCollection('services');
  return services.map(entry => ({
    params: { id: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

// Fetch related services details
const relatedServices = await Promise.all(
  (entry.data.relatedServices || []).map(async (relatedId) => {
    return await getEntry('services', relatedId);
  })
).then(results => results.filter(Boolean));

// Fetch blog posts that relate to this service
const allBlogPosts = await getCollection('blog');
const relatedBlogPosts = allBlogPosts.filter(post => 
  (post.data.relatedServices || []).includes(entry.id)
);

// Dynamic FAQ Schema Markup
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": (entry.data.faqs || []).map(faq => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer
    }
  }))
};
---

<Layout 
  title={`${entry.data.title} | One Smile Dental Care`}
  description={entry.data.description}
  image={entry.data.image}
>
  {/* Inject FAQ Schema for Rich Snippets */}
  {entry.data.faqs && entry.data.faqs.length > 0 && (
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  )}

  <article class="bg-stone-50 min-h-screen">
    {/* Page Header */}
    <header class="py-16 bg-stone-900 text-white relative overflow-hidden">
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,_var(--tw-gradient-stops))] from-teal-950/30 via-stone-950 to-stone-950 opacity-90 z-0"></div>
      <div class="relative z-10 max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <a href="/services" class="inline-flex items-center gap-2 text-sm text-teal-400 hover:text-teal-300 font-semibold mb-6 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
          </svg>
          Back to Services
        </a>
        <h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight mb-4">{entry.data.title}</h1>
        <p class="text-lg text-stone-300 max-w-3xl font-light leading-relaxed">{entry.data.summary}</p>
      </div>
    </header>

    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
        
        {/* Main Content Area */}
        <div class="lg:col-span-8 flex flex-col gap-10">
          
          {/* Main Visual Anchor */}
          <div class="aspect-video w-full rounded-2xl overflow-hidden bg-stone-200 shadow-lg border border-stone-200">
            <img 
              src={entry.data.image} 
              alt={`Clinical details for ${entry.data.title}`} 
              class="w-full h-full object-cover"
            />
          </div>

          {/* Markdown Content */}
          <div class="prose prose-stone max-w-none prose-headings:text-stone-900 prose-p:text-stone-700 prose-strong:text-stone-900 leading-relaxed">
            <Content />
          </div>

          {/* FAQs section */}
          {entry.data.faqs && entry.data.faqs.length > 0 && (
            <div class="border-t border-stone-200 pt-10">
              <h2 class="text-2xl sm:text-3xl font-extrabold text-stone-900 mb-6">Frequently Asked Questions</h2>
              <div class="flex flex-col gap-3">
                {entry.data.faqs.map((faq, idx) => (
                  <div class="collapse collapse-plus bg-white border border-stone-200 rounded-xl">
                    <input type="radio" name="faq-accordion" checked={idx === 0 ? "checked" : undefined} /> 
                    <div class="collapse-title text-base font-bold text-stone-900 pr-12">
                      {faq.question}
                    </div>
                    <div class="collapse-content text-sm text-stone-600 leading-relaxed">
                      <p>{faq.answer}</p>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          )}

        </div>

        {/* Sidebar Info Area */}
        <div class="lg:col-span-4 flex flex-col gap-8">
          
          {/* Treatment Benefits */}
          {entry.data.benefits && entry.data.benefits.length > 0 && (
            <div class="bg-white border border-stone-200 rounded-2xl p-6 shadow-sm">
              <h3 class="font-bold text-stone-900 text-lg mb-4 border-b border-stone-100 pb-2">Key Benefits</h3>
              <ul class="flex flex-col gap-3">
                {entry.data.benefits.map(benefit => (
                  <li class="flex items-start gap-3 text-sm text-stone-700 leading-relaxed">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-teal-600 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                    </svg>
                    <span>{benefit}</span>
                  </li>
                ))}
              </ul>
            </div>
          )}

          {/* Treatment metadata */}
          {entry.data.treatmentTime && (
            <div class="bg-stone-900 text-white rounded-2xl p-6 shadow-sm flex flex-col gap-4">
              <h3 class="font-bold text-teal-400 text-sm uppercase tracking-wider">Treatment Info</h3>
              <div class="flex flex-col gap-2">
                <span class="text-xs text-stone-400">Estimated Duration:</span>
                <span class="text-base font-bold text-stone-100">{entry.data.treatmentTime}</span>
              </div>
              <div class="divider border-stone-800 my-1"></div>
              <a 
                href={`https://wa.me/918400021200?text=Hello%20One%20Smile%20Dental%20Care,%20I%20am%20interested%20in%20learning%20more%20about%20${encodeURIComponent(entry.data.title)}`}
                target="_blank" 
                rel="noopener noreferrer" 
                class="btn btn-primary text-white w-full text-center"
              >
                Inquire via WhatsApp
              </a>
            </div>
          )}

          {/* Related Blog Posts */}
          {relatedBlogPosts.length > 0 && (
            <div class="bg-white border border-stone-200 rounded-2xl p-6 shadow-sm">
              <h3 class="font-bold text-stone-900 text-lg mb-4 border-b border-stone-100 pb-2">Related Articles</h3>
              <div class="flex flex-col gap-4">
                {relatedBlogPosts.map(post => (
                  <a href={`/blog/${post.id}`} class="group flex flex-col gap-1.5 focus:outline-none">
                    <h4 class="text-sm font-bold text-stone-900 group-hover:text-teal-600 transition-colors leading-snug">
                      {post.data.title}
                    </h4>
                    <span class="text-xs text-stone-400 font-medium">
                      Published {new Date(post.data.pubDate).toLocaleDateString(undefined, {month: 'short', day: 'numeric', year: 'numeric'})}
                    </span>
                  </a>
                ))}
              </div>
            </div>
          )}

          {/* Related Services */}
          {relatedServices.length > 0 && (
            <div class="bg-white border border-stone-200 rounded-2xl p-6 shadow-sm">
              <h3 class="font-bold text-stone-900 text-lg mb-4 border-b border-stone-100 pb-2">Related Treatments</h3>
              <div class="flex flex-col gap-4">
                {relatedServices.map(relService => (
                  <a href={`/services/${relService.id}`} class="group flex items-center gap-3 focus:outline-none">
                    <div class="w-12 h-12 rounded-lg overflow-hidden bg-stone-100 shrink-0">
                      <img 
                        src={relService.data.image} 
                        alt={relService.data.title} 
                        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                      />
                    </div>
                    <div class="flex flex-col">
                      <h4 class="text-sm font-bold text-stone-900 group-hover:text-teal-600 transition-colors leading-tight">
                        {relService.data.title}
                      </h4>
                      <span class="text-xs text-stone-500 line-clamp-1 mt-0.5">
                        {relService.data.summary}
                      </span>
                    </div>
                  </a>
                ))}
              </div>
            </div>
          )}

        </div>

      </div>
    </div>
  </article>
</Layout>
