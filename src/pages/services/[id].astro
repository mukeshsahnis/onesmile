---
import Layout from '../../layouts/Layout.astro';
import { getCollection, getEntry, render } from 'astro:content';

export async function getStaticPaths() {
  const services = await getCollection('services');
  return services.map(entry => ({
    params: { id: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

// Fetch related services details
const relatedServices = await Promise.all(
  (entry.data.relatedServices || []).map(async (relatedId) => {
    return await getEntry('services', relatedId);
  })
).then(results => results.filter(Boolean));

// Fetch blog posts that relate to this service
const allBlogPosts = await getCollection('blog');
const relatedBlogPosts = allBlogPosts.filter(post =>
  (post.data.relatedServices || []).includes(entry.id)
);

// Dynamic FAQ Schema Markup
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": (entry.data.faqs || []).map(faq => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer
    }
  }))
};
---

<Layout
  title={`${entry.data.title} | One Smile Dental Care`}
  description={entry.data.description}
  image={entry.data.image}
>
  {/* Inject FAQ Schema for Rich Snippets */}
  {entry.data.faqs && entry.data.faqs.length > 0 && (
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  )}

  <article class="bg-stone-50 min-h-screen">
    <nav class="bg-white border-b border-stone-200 py-8 animate-[fadeIn_0.5s_ease_forwards]" aria-label="Breadcrumb">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col gap-2">
        <ol class="flex items-center gap-2 text-xs font-bold uppercase tracking-wider text-stone-500">
          <li>
            <a href={base} class="hover:text-teal-600 transition-colors">Home</a>
          </li>
          <li class="flex items-center gap-2 text-stone-400">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" />
            </svg>
            <a href={`${base}services`} class="hover:text-teal-600 transition-colors">Services</a>
          </li>
          <li class="flex items-center gap-2 text-stone-400">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" />
            </svg>
            <span class="text-teal-600 truncate max-w-[200px] sm:max-w-xs">{entry.data.title}</span>
          </li>
        </ol>
        <h1 class="text-3xl font-extrabold text-stone-900 mt-2 leading-tight">{entry.data.title}</h1>
        <p class="text-sm text-stone-500 max-w-3xl mt-1 leading-relaxed">{entry.data.summary}</p>
      </div>
    </nav>

    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">

        {/* Main Content Area */}
        <div class="lg:col-span-8 flex flex-col gap-10">

          {/* Main Visual Anchor */}
          <div class="aspect-video w-full rounded-2xl overflow-hidden bg-stone-200 shadow-lg border border-stone-200">
            <img
              src={entry.data.image.startsWith('/') ? `${base}${entry.data.image.slice(1)}` : entry.data.image}
              alt={`Clinical details for ${entry.data.title}`}
              class="w-full h-full object-cover"
            />
          </div>

          {/* Quick summary first, so a service page does not feel too heavy */}
          <section class="bg-white border border-stone-200 rounded-2xl p-6 sm:p-8 shadow-sm">
            <span class="text-xs font-bold uppercase tracking-widest text-teal-600">Quick Summary</span>
            <h2 class="text-2xl sm:text-3xl font-extrabold text-stone-900 mt-3 mb-3">What this treatment helps with</h2>
            <p class="text-base sm:text-lg text-stone-600 leading-relaxed">{entry.data.summary}</p>
            {entry.data.benefits && entry.data.benefits.length > 0 && (
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mt-6">
                {entry.data.benefits.slice(0, 4).map(benefit => (
                  <div class="flex items-start gap-2.5 text-sm text-stone-700 bg-stone-50 border border-stone-100 rounded-xl p-3">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-teal-600 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                    </svg>
                    <span>{benefit}</span>
                  </div>
                ))}
              </div>
            )}
          </section>

          {/* Detailed treatment information is available on demand */}
          <details class="collapse collapse-arrow bg-white border border-stone-200 rounded-2xl shadow-sm">
            <summary class="collapse-title text-xl font-bold text-stone-900 pr-12">
              Read detailed treatment information
            </summary>
            <div class="collapse-content">
              <div class="prose prose-stone max-w-none prose-headings:text-stone-900 prose-p:text-stone-700 prose-strong:text-stone-900 leading-relaxed pt-2">
                <Content />
              </div>
            </div>
          </details>

          {/* FAQs section */}
          {entry.data.faqs && entry.data.faqs.length > 0 && (
            <div class="border-t border-stone-200 pt-10">
              <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-3 mb-6">
                <div>
                  <span class="text-xs font-bold uppercase tracking-widest text-teal-600">FAQs</span>
                  <h2 class="text-2xl sm:text-3xl font-extrabold text-stone-900 mt-2">Frequently Asked Questions</h2>
                </div>
                <a href={`${base}blog`} class="text-sm font-semibold text-teal-700 hover:text-teal-900">Read related blogs</a>
              </div>
              <div class="flex flex-col gap-3">
                {entry.data.faqs.map((faq) => (
                  <div class="collapse collapse-plus bg-white border border-stone-200 rounded-xl">
                    <input type="radio" name="faq-accordion" />
                    <div class="collapse-title text-base font-bold text-stone-900 pr-12">
                      {faq.question}
                    </div>
                    <div class="collapse-content text-sm text-stone-600 leading-relaxed">
                      <p>{faq.answer}</p>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          )}

        </div>

        {/* Sidebar Info Area */}
        <div class="lg:col-span-4 flex flex-col gap-8">

          {/* Treatment Benefits */}
          {entry.data.benefits && entry.data.benefits.length > 0 && (
            <div class="bg-white border border-stone-200 rounded-2xl p-6 shadow-sm">
              <h3 class="font-bold text-stone-900 text-lg mb-4 border-b border-stone-100 pb-2">Key Benefits</h3>
              <ul class="flex flex-col gap-3">
                {entry.data.benefits.map(benefit => (
                  <li class="flex items-start gap-3 text-sm text-stone-700 leading-relaxed">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-teal-600 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                    </svg>
                    <span>{benefit}</span>
                  </li>
                ))}
              </ul>
            </div>
          )}

          {/* Treatment metadata */}
          {entry.data.treatmentTime && (
            <div class="bg-stone-900 text-white rounded-2xl p-6 shadow-sm flex flex-col gap-4">
              <h3 class="font-bold text-teal-400 text-sm uppercase tracking-wider">Treatment Info</h3>
              <div class="flex flex-col gap-2">
                <span class="text-xs text-stone-400">Estimated Duration:</span>
                <span class="text-base font-bold text-stone-100">{entry.data.treatmentTime}</span>
              </div>
              <div class="divider border-stone-800 my-1"></div>
              <a
                href={`https://wa.me/918400021200?text=Hello%20One%20Smile%20Dental%20Care,%20I%20am%20interested%20in%20learning%20more%20about%20${encodeURIComponent(entry.data.title)}`}
                target="_blank"
                rel="noopener noreferrer"
                class="btn btn-primary text-white w-full text-center"
              >
                Inquire via WhatsApp
              </a>
            </div>
          )}

          {/* Related Blog Posts */}
          {relatedBlogPosts.length > 0 && (
            <div class="bg-white border border-stone-200 rounded-2xl p-6 shadow-sm">
              <h3 class="font-bold text-stone-900 text-lg mb-4 border-b border-stone-100 pb-2">Related Articles</h3>
              <div class="flex flex-col gap-4">
                {relatedBlogPosts.map(post => (
                  <a href={`${base}blog/${post.id}`} class="group flex flex-col gap-1.5 focus:outline-none">
                    <h4 class="text-sm font-bold text-stone-900 group-hover:text-teal-600 transition-colors leading-snug">
                      {post.data.title}
                    </h4>
                    <span class="text-xs text-stone-400 font-medium">
                      Published {new Date(post.data.pubDate).toLocaleDateString(undefined, {month: 'short', day: 'numeric', year: 'numeric'})}
                    </span>
                  </a>
                ))}
              </div>
            </div>
          )}

          {/* Related Services */}
          {relatedServices.length > 0 && (
            <div class="bg-white border border-stone-200 rounded-2xl p-6 shadow-sm">
              <h3 class="font-bold text-stone-900 text-lg mb-4 border-b border-stone-100 pb-2">Related Treatments</h3>
              <div class="flex flex-col gap-4">
                {relatedServices.map(relService => (
                  <a href={`${base}services/${relService.id}`} class="group flex items-center gap-3 focus:outline-none">
                    <div class="w-12 h-12 rounded-lg overflow-hidden bg-stone-100 shrink-0">
                      <img
                        src={relService.data.image.startsWith('/') ? `${base}${relService.data.image.slice(1)}` : relService.data.image}
                        alt={relService.data.title}
                        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                      />
                    </div>
                    <div class="flex flex-col">
                      <h4 class="text-sm font-bold text-stone-900 group-hover:text-teal-600 transition-colors leading-tight">
                        {relService.data.title}
                      </h4>
                      <span class="text-xs text-stone-500 line-clamp-1 mt-0.5">
                        {relService.data.summary}
                      </span>
                    </div>
                  </a>
                ))}
              </div>
            </div>
          )}

        </div>

      </div>
    </div>
  </article>
</Layout>
