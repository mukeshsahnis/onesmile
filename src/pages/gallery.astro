---
import Layout from '../layouts/Layout.astro';

const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;

const clinicImages = [
  { src: "/clinic/treating-patient.jpg", title: "Patient Treatment Studio", category: "Facility" },
  { src: "/clinic/ster.jpg", title: "Class-B Autoclave Sterilizer", category: "Sterilization" },
  { src: "/clinic/wtarepurif.webp", title: "Closed-Loop Pure Water Unit", category: "Technology" },
  { src: "/clinic/xray.jpg", title: "Digital X-Ray Diagnoses", category: "Technology" },
  { src: "/clinic/dental.jpg", title: "Dental Operatory", category: "Facility" },
  { src: "/clinic/tools.jpg", title: "Endodontic Rotary Instruments", category: "Equipment" }
].map(img => ({ ...img, src: `${base}${img.src.replace(/^\//, '')}` }));

const patientPhotos = [
  "/patients/patient1.jpg",
  "/patients/patient2.jpg",
  "/patients/patient3.jpg",
  "/patients/patient4.jpg",
  "/patients/patient5.jpg",
  "/patients/patient6.jpg",
  "/patients/patient7.jpg",
  "/patients/patient8.jpg",
  "/patients/patient9.jpg",
  "/patients/patient10.jpg"
].map(path => `${base}${path.replace(/^\//, '')}`);
---

<Layout 
  title="Clinic Gallery | One Smile Dental Care"
  description="Take a visual tour of One Smile Dental Care. See our sterile operatory, advanced dental equipment, water purification setups, and beautiful patient results."
>
  <section class="py-20 bg-stone-900 text-white relative overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,_var(--tw-gradient-stops))] from-teal-950/40 via-stone-950 to-stone-950 opacity-90 z-0"></div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center py-10">
      <span class="text-xs font-bold uppercase tracking-widest text-teal-400">Visual Tour</span>
      <h1 class="text-4xl sm:text-6xl font-extrabold tracking-tight mt-3 mb-6">Clinic & Results Gallery</h1>
      <p class="text-lg sm:text-xl text-stone-300 max-w-2xl mx-auto font-light">
        A transparent look inside our sterile operatory rooms, advanced diagnostic technology, and healthy patient smiles.
      </p>
    </div>
  </section>

  {/* Clinic Facility Gallery */}
  <section class="py-20 bg-stone-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <span class="text-xs font-bold uppercase tracking-widest text-teal-600">The Studio</span>
        <h2 class="text-3xl sm:text-4xl font-extrabold text-stone-900 mt-2 mb-4">Our Facilities & Technology</h2>
        <p class="text-base text-stone-600">
          We maintain strict sterilization standards and clinical technologies for maximum safety and comfort.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
        {clinicImages.map(img => (
          <div class="group relative overflow-hidden rounded-2xl border border-stone-200 bg-white shadow-sm transition-all duration-300 hover:shadow-md">
            <div class="aspect-video w-full overflow-hidden bg-stone-100 relative">
              <img 
                src={img.src} 
                alt={img.title} 
                class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-103"
                loading="lazy"
              />
              <div class="absolute top-4 left-4 bg-stone-950/80 backdrop-blur-md px-3 py-1 rounded-full text-xs font-semibold text-teal-400 border border-stone-850">
                {img.category}
              </div>
            </div>
            <div class="p-5">
              <h3 class="font-bold text-stone-900 text-base">{img.title}</h3>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* Patient Smile Gallery */}
  <section class="py-20 bg-stone-100 border-t border-stone-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <span class="text-xs font-bold uppercase tracking-widest text-teal-600">Happy Patients</span>
        <h2 class="text-3xl sm:text-4xl font-extrabold text-stone-900 mt-2 mb-4">Smile Transformations</h2>
        <p class="text-base text-stone-600">
          Actual results showcasing corrected teeth alignments, smile makeovers, and successful dental implants.
        </p>
      </div>

      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-6">
        {patientPhotos.map((photo, idx) => (
          <div class="group relative overflow-hidden rounded-xl border border-stone-200 shadow-sm aspect-square bg-white">
            <img 
              src={photo} 
              alt={`One Smile patient transformation ${idx + 1}`} 
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-stone-950/50 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end p-4">
              <span class="text-xs text-white font-semibold">Smile Design #{idx + 1}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>
