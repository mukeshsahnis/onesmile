---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allTreatments = await getCollection('treatments');
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const featuredTreatmentIds = [
  'dental-implant',
  'root-canal-treatment',
  'braces-and-aligners',
  'smile-makeover',
];
const featuredTreatments = allTreatments
  .filter((treatment) => featuredTreatmentIds.includes(treatment.id))
  .sort((a, b) => featuredTreatmentIds.indexOf(a.id) - featuredTreatmentIds.indexOf(b.id));

const patientPhotos = [
  "/patients/patient1.jpg",
  "/patients/patient2.jpg",
  "/patients/patient3.jpg",
  "/patients/patient4.jpg",
  "/patients/patient5.jpg",
  "/patients/patient6.jpg",
  "/patients/patient7.jpg",
  "/patients/patient8.jpg",
  "/patients/patient9.jpg",
  "/patients/patient10.jpg",
].map(path => `${base}${path.replace(/^\//, '')}`);

const googleReviews = [
  {
    name: "aashish singh",
    rating: 5,
    text: "Initial inspection was fine. Would visit again for through treatment. On initial inspection its good",
    date: "2 weeks ago",
    avatar: "https://lh3.googleusercontent.com/a-/ALV-UjW8EaXS8IsjaKkIj-pgbJzmPaGSte1gfVPPFx33DVLabuz07BeL=w144-h144-p-rp-mo-br100"
  },
  {
    name: "muskan gurnani",
    rating: 5,
    text: "I’ve gotten my pre wedding - teeth whitening done from Dr Radhika Rastogi at one smile dental care. Would highly recommend her!!",
    date: "2 months ago",
    avatar: "https://lh3.googleusercontent.com/a-/ALV-UjWWsXoVLVZvvwOAMmgGvil3IMjTLJHSmWO_rEFOBKZ8pxGVVhwB=w144-h144-p-rp-mo-br100"
  },
  {
    name: "Meenakshi Manas",
    rating: 5,
    text: "Wonderful treat. Painless and done soo perfectly by Dr Radhika. I am delighted by the efforts taken by her so ensure patient wellbeing. Thank you.",
    date: "3 months ago",
    avatar: null,
    avatarBg: "bg-[#319795]"
  },
  {
    name: "Ananya Srivastava 13",
    rating: 5,
    text: "Had a great experience at One Smile Dental Clinic, Lucknow. Dr. Radhika Rastogi, Dr. Abhigyan, Dr. Neelam and the entire team handled my mother’s fractured tooth extraction very smoothly and with great care. The doctors were kind, professional, and made her feel comfortable. Highly recommended!",
    date: "4 months ago",
    avatar: null,
    avatarBg: "bg-[#319795]"
  },
  {
    name: "Shantam Bharti",
    rating: 5,
    text: "Dr Radhika Rastogi is well versed, very patient with her task, pinpoint with her diagnosis and strategy to remediate patients problem. Her hand is very soft and steady during the procedure which is utmost important during any dental care procedures. Strongly recommend this Dental Care clinic.",
    date: "4 months ago",
    avatar: "https://lh3.googleusercontent.com/a-/ALV-UjXrMcNozcGPAiIWszAW7UpzPP2zA9yvn7NgsTI0wszcXDJdC3jfnw=w144-h144-p-rp-mo-br100"
  },
  {
    name: "yashi srivastava",
    rating: 5,
    text: "Doctor Radhika Maam is very sweet and handles her patient very gently, all the procedures done by her are painless and very gently handled. The staff is very good and the clinic gives a very calming vibes.",
    date: "4 months ago",
    avatar: null,
    avatarBg: "bg-[#805ad5]"
  },
  {
    name: "Tarun Singh",
    rating: 5,
    text: "Great dental care with proper hygiene. Doctor explained everything clearly.",
    date: "4 months ago",
    avatar: null,
    avatarBg: "bg-[#4a5568]"
  },
  {
    name: "sunita singh",
    rating: 5,
    text: "Today I visited the clinic, the clinic is very neat and clean, drs are very good and expert, my both implants are done just in 25 min without surgical cut. I was very nervous but it was good experience. who hv any dental problems visit this clinic. thank you for all the Drs",
    date: "6 months ago",
    avatar: null,
    avatarBg: "bg-[#2b6cb0]"
  },
  {
    name: "Prekshi Garg",
    rating: 5,
    text: "I had an exceptional experience at One Smile. My dentist, Dr Radhika Rastogi, was outstanding! She explained everything clearly, answered all my questions, and made sure I was comfortable throughout the procedure. Really impressed with their treatment. i would surely recommend One Smile Dental Clinic to everyone..!!",
    date: "a year ago",
    avatar: "https://lh3.googleusercontent.com/a-/ALV-UjWLjSNJCc46gAZU4ThlOj_ZK5jfsVSjENojQGG4WQ_LMjamP8IoQA=w144-h144-p-rp-mo-br100"
  },
  {
    name: "Ankita Garg",
    rating: 5,
    text: "One Smile Dental Care is one of the best clinics I have attended. It is so neat clean with all whites nicely maintained. They have a very courteous set of staff and all facilities under one roof. They are really good and very smooth with …",
    date: "5 years ago",
    avatar: null,
    avatarBg: "bg-[#e53e3e]"
  }
];
---

<Layout title="One Smile Dental Care | Premier Dental Implants & Smile Makeovers">
  {/* SECTION 1: HERO - One Composition, Brand First, Full-bleed */}
  <section class="relative min-h-[90vh] flex items-end justify-center text-white overflow-hidden bg-stone-950 pb-6 sm:pb-10">
    {/* Full-bleed dominant background image */}
    <div class="absolute inset-0 z-0">
      <img
        src={`${base}banners/banner.jpg`}
        alt="Smiling patient showing beautiful white teeth"
        class="w-full h-full object-cover object-center opacity-90 scale-105 animate-[zoomOut_20s_ease-out_forwards]"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-stone-950/80 via-stone-900/20 to-transparent z-10"></div>
    </div>

    {/* Hero content aligned left to prevent covering doctor/team faces on the right */}
    <div class="relative z-20 max-w-7xl w-full mx-auto px-4 sm:px-6 lg:px-8 text-left flex flex-col items-start gap-4">
      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-black tracking-wider leading-[1.1] text-white max-w-2xl animate-[fadeInUp_1s_ease_forwards_0.2s] opacity-0 fill-mode-forwards">
        YOUR BRIGHT & BEAUTIFUL<br />
        <span class="text-teal-400">SMILE</span><br />
        BEGINS HERE
      </h1>
      <p class="text-base sm:text-lg text-stone-100 max-w-xl leading-relaxed animate-[fadeInUp_1s_ease_forwards_0.4s] opacity-0 fill-mode-forwards">
        Specialist-led, comfort-first dental care with transparent treatment planning in Lucknow.
      </p>
      <div class="flex flex-wrap items-center justify-start gap-4 mt-2 animate-[fadeInUp_1s_ease_forwards_0.6s] opacity-0 fill-mode-forwards">
        <a href="https://wa.me/918400021200" target="_blank" rel="noopener noreferrer" class="btn btn-primary btn-lg text-base font-bold shadow-lg shadow-teal-500/20 hover:scale-105 transition-transform duration-300">
          Book Appointment
        </a>
        <a href={`${base}treatments`} class="btn btn-outline btn-lg text-white hover:bg-white hover:text-stone-950 border-white/60 hover:border-white transition-all duration-300">
          Explore Treatments
        </a>
      </div>
    </div>
  </section>

  {/* SECTION 2: TRUST SIGNALS - Immediate reasons to feel confident */}
  <section class="relative z-30 bg-white border-b border-stone-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 lg:gap-6">
        <div class="flex items-center gap-3 rounded-xl bg-stone-50 border border-stone-200 p-4">
          <div class="h-10 w-10 rounded-full bg-white border border-stone-200 shadow-sm flex items-center justify-center shrink-0">
            <svg class="h-5 w-5" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-label="Google">
              <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4" />
              <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853" />
              <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.06H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.94l2.85-2.22.81-.63z" fill="#FBBC05" />
              <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.06l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335" />
            </svg>
          </div>
          <div>
            <div class="font-extrabold text-stone-900">4.9 Google Rating</div>
            <div class="text-xs text-stone-500">Trusted patient experiences</div>
          </div>
        </div>
        <div class="flex items-center gap-3 rounded-xl bg-stone-50 border border-stone-200 p-4">
          <div class="h-10 w-10 rounded-full bg-teal-100 text-teal-700 flex items-center justify-center shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l6.16-3.422A12.083 12.083 0 0118 15.5C18 17.433 15.314 19 12 19s-6-1.567-6-3.5c0-1.77.224-3.32.84-4.922L12 14z"/></svg>
          </div>
          <div>
            <div class="font-extrabold text-stone-900">Specialist-led Care</div>
            <div class="text-xs text-stone-500">AIIMS & KGMC experience</div>
          </div>
        </div>
        <div class="flex items-center gap-3 rounded-xl bg-stone-50 border border-stone-200 p-4">
          <div class="h-10 w-10 rounded-full bg-sky-100 text-sky-700 flex items-center justify-center shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
          </div>
          <div>
            <div class="font-extrabold text-stone-900">Class-B Sterilization</div>
            <div class="text-xs text-stone-500">Strict hygiene protocols</div>
          </div>
        </div>
        <div class="flex items-center gap-3 rounded-xl bg-stone-50 border border-stone-200 p-4">
          <div class="h-10 w-10 rounded-full bg-rose-100 text-rose-700 flex items-center justify-center shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </div>
          <div>
            <div class="font-extrabold text-stone-900">Gentle Dentistry</div>
            <div class="text-xs text-stone-500">Clear, comfort-first care</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* SECTION 3: DR RADHIKA - Lead with the clinician behind the care */}
  <section class="py-20 lg:py-24 bg-stone-100 border-b border-stone-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-14 items-center">
        <div class="lg:col-span-5 relative">
          <div class="aspect-[3/4] w-full rounded-2xl overflow-hidden bg-stone-200 shadow-2xl relative">
            <img
              src={`${base}doctors/doctor-radhika-1.jpg`}
              alt="Dr. Radhika Rastogi, lead dentist at One Smile Dental Care"
              class="w-full h-full object-cover"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-stone-900/70 via-transparent to-transparent"></div>
            <div class="absolute bottom-6 left-6 right-6 text-white z-10">
              <div class="text-xl font-bold">Dr. Radhika Rastogi</div>
              <div class="text-xs text-teal-300 font-semibold uppercase tracking-wider mt-1">MDS, Endodontics & Aesthetics</div>
            </div>
          </div>
        </div>
        <div class="lg:col-span-7 flex flex-col gap-6">
          <div>
            <span class="text-xs font-bold uppercase tracking-widest text-teal-600">Meet your dentist</span>
            <h2 class="text-3xl sm:text-5xl font-extrabold text-stone-900 mt-3 leading-tight">Expert care begins with listening.</h2>
          </div>
          <p class="text-lg text-stone-600 leading-relaxed">
            Dr. Radhika Rastogi is a senior resident from AIIMS & KGMC she did her MDS in Endodontics & Aesthetics Dentistry. Owning the best dental clinic in Lucknow “ One Smile Dental Care” She makes every attempt to provide her patients with top-notch, painless multiple/single visit root canal treatment and other dental services.
          </p>
          <div class="max-w-md">
            <a href="https://www.instagram.com/onesmile_dentalcare/reel/DTfIbaBkTc7/" target="_blank" rel="noopener noreferrer" class="group flex items-center gap-4 bg-white border border-stone-200 rounded-2xl p-3 hover:border-teal-400 hover:shadow-md transition-all">
              <div class="relative w-20 h-20 rounded-xl overflow-hidden bg-stone-200 shrink-0">
                <img src={`${base}social/doctor-interview.webp`} alt="Dr. Radhika Rastogi discussing her approach to patient care" class="w-full h-full object-cover" loading="lazy" />
                <span class="absolute inset-0 bg-stone-950/20 flex items-center justify-center" aria-hidden="true">
                  <span class="w-8 h-8 rounded-full bg-white/95 text-teal-700 flex items-center justify-center shadow"><svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 ml-0.5 fill-current" viewBox="0 0 20 20"><path d="M6.5 5.5a1 1 0 011.54-.84l7 4.5a1 1 0 010 1.68l-7 4.5A1 1 0 016.5 14.5v-9z"/></svg></span>
                </span>
              </div>
              <div>
                <div class="text-xs font-bold uppercase tracking-wider text-teal-600">Doctor conversation</div>
                <div class="font-bold text-stone-900 group-hover:text-teal-700 mt-1">Meet Dr. Radhika</div>
                <div class="text-xs text-stone-500 mt-1">Watch on Instagram</div>
              </div>
            </a>
          </div>
          <div class="flex flex-wrap gap-4 pt-2">
            <a href={`${base}about`} class="btn btn-primary text-white">Know Your Dentist</a>
            <a href="https://wa.me/918400021200" target="_blank" rel="noopener noreferrer" class="btn btn-outline border-stone-300">Ask a Question</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* SECTION 4: FEATURED TREATMENTS - A concise path to common needs */}
  <section class="py-16 lg:py-20 bg-stone-50 border-b border-stone-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-6 mb-12">
        <div class="max-w-3xl">
          <span class="text-xs font-bold uppercase tracking-widest text-teal-600">How we can help</span>
          <h2 class="text-3xl sm:text-5xl font-extrabold text-stone-900 mt-3">Care for the smiles that matter most.</h2>
          <p class="text-lg text-stone-600 mt-4">Explore a focused selection of our most requested treatments. Your consultation always begins with a careful diagnosis and a plan tailored to you.</p>
        </div>
        <a href={`${base}treatments`} class="btn btn-primary btn-outline font-semibold shrink-0">Explore All Treatments</a>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {featuredTreatments.map(treatment => (
          <a href={`${base}treatments/${treatment.id}`} class="group overflow-hidden bg-white rounded-2xl border border-stone-200 hover:shadow-xl hover:border-teal-500/30 transition-all duration-300">
            <div class="aspect-[4/3] w-full overflow-hidden bg-stone-100">
              <img
                src={treatment.data.image.startsWith('/') ? `${base}${treatment.data.image.slice(1)}` : treatment.data.image}
                alt={treatment.data.title}
                class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                loading="lazy"
              />
            </div>
            <div class="p-5">
              <h3 class="text-lg font-bold text-stone-900 group-hover:text-teal-600 transition-colors">{treatment.data.title}</h3>
              <p class="text-sm text-stone-600 leading-relaxed line-clamp-2 mt-2">{treatment.data.summary}</p>
              <span class="inline-flex items-center gap-2 text-sm font-semibold text-teal-600 mt-4">Treatment details <span aria-hidden="true">→</span></span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  {/* SECTION 5: PATIENT SMILE CAROUSEL - Premium Grid Carousel */}
  <section class="py-16 lg:py-20 bg-stone-50 overflow-hidden border-b border-stone-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      {/* Carousel Header (Centered) */}
      <div class="text-center max-w-3xl mx-auto mb-12">
        <h2 class="text-3xl sm:text-5xl font-extrabold text-stone-900 mb-4">Patient Smile Transformations</h2>
        <p class="text-lg text-stone-600">
          View the real results of our cosmetic and orthodontic treatments, highlighting dental wellness and aesthetic excellence.
        </p>
      </div>

      {/* Carousel Container with Absolute Overlay Buttons */}
      <div class="relative w-full group/carousel">

        {/* Prev Button (Absolute Left Edge) */}
        <button id="carousel-prev" class="absolute -left-4 sm:left-4 top-1/2 -translate-y-1/2 btn btn-circle bg-white/80 backdrop-blur-md border-stone-200 text-stone-700 shadow-lg hover:bg-teal-600 hover:text-white hover:border-teal-600 transition-all duration-300 z-10" aria-label="Previous Slide">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 19l-7-7 7-7" />
          </svg>
        </button>

        {/* Next Button (Absolute Right Edge) */}
        <button id="carousel-next" class="absolute -right-4 sm:right-4 top-1/2 -translate-y-1/2 btn btn-circle bg-white/80 backdrop-blur-md border-stone-200 text-stone-700 shadow-lg hover:bg-teal-600 hover:text-white hover:border-teal-600 transition-all duration-300 z-10" aria-label="Next Slide">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" />
          </svg>
        </button>

        {/* Grid Track Carousel */}
        <div id="transformation-carousel" class="carousel w-full gap-6 py-4 scroll-smooth">
          {patientPhotos.map((photo, idx) => (
            <div id={`slide-${idx}`} class="carousel-item w-full sm:w-[calc(50%-12px)] md:w-[calc(33.333%-16px)] flex flex-col bg-white border border-stone-200 rounded-2xl overflow-hidden shadow-sm hover:shadow-md transition-all duration-300">
              <div class="aspect-[4/3] w-full overflow-hidden bg-stone-100">
                <img
                  src={photo}
                  alt={`One Smile patient transformation ${idx + 1}`}
                  class="w-full h-full object-cover transition-transform duration-500 hover:scale-105"
                  loading="lazy"
                />
              </div>
              <div class="p-4 bg-white border-t border-stone-100 flex items-center justify-between">
                <span class="text-sm font-bold text-stone-800">Smile Transformation {idx + 1}</span>
                <span class="text-xs font-semibold uppercase tracking-wider text-teal-600 bg-teal-50 px-2.5 py-1 rounded-full border border-teal-100/50">Successful</span>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>

    {/* Client side navigation handling */}
    <script>
      document.addEventListener('astro:page-load', () => {
        const prevBtn = document.getElementById('carousel-prev');
        const nextBtn = document.getElementById('carousel-next');
        const track = document.getElementById('transformation-carousel');

        if (prevBtn && nextBtn && track) {
          prevBtn.addEventListener('click', () => {
            const itemWidth = track.firstElementChild?.clientWidth || 300;
            track.scrollBy({ left: -(itemWidth + 24), behavior: 'smooth' });
          });

          nextBtn.addEventListener('click', () => {
            const itemWidth = track.firstElementChild?.clientWidth || 300;
            track.scrollBy({ left: itemWidth + 24, behavior: 'smooth' });
          });
        }
      });
    </script>
  </section>

  {/* SECTION 6: GOOGLE REVIEWS - Premium Google Reviews Carousel */}
  <section class="py-16 lg:py-20 bg-[#f8f9fa] border-b border-stone-200/60 relative overflow-hidden">
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      {/* Reviews introduction; the rating itself is shown once in the trust strip above. */}
      <div class="text-center max-w-3xl mx-auto mb-12">
        <span class="text-xs font-bold uppercase tracking-widest text-teal-600">Patient experiences</span>
        <h2 class="text-3xl sm:text-5xl font-extrabold text-stone-900 mt-3">What our patients say.</h2>
        <p class="text-lg text-stone-600 mt-4">Real feedback from patients who trusted One Smile with their dental care.</p>
      </div>

      <div class="relative w-full">
        {/* Navigation Buttons (matching transformation-carousel style) */}
        <button id="reviews-prev" class="absolute -left-4 sm:left-4 top-1/2 -translate-y-1/2 btn btn-circle bg-white/80 backdrop-blur-md border-stone-200 text-stone-700 shadow-lg hover:bg-teal-600 hover:text-white hover:border-teal-600 transition-all duration-300 z-10 flex items-center justify-center" aria-label="Previous Review">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 19l-7-7 7-7" />
          </svg>
        </button>
        <button id="reviews-next" class="absolute -right-4 sm:right-4 top-1/2 -translate-y-1/2 btn btn-circle bg-white/80 backdrop-blur-md border-stone-200 text-stone-700 shadow-lg hover:bg-teal-600 hover:text-white hover:border-teal-600 transition-all duration-300 z-10 flex items-center justify-center" aria-label="Next Review">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" />
          </svg>
        </button>

        {/* Carousel Track */}
        <div id="reviews-carousel" class="flex gap-8 lg:gap-10 overflow-x-auto snap-x snap-mandatory scroll-smooth no-scrollbar pb-6 px-1">
          {googleReviews.map((review) => {
            const colors = ["bg-[#4a5568]", "bg-[#0084ff]", "bg-[#10b981]", "bg-[#e11d48]", "bg-[#6366f1]", "bg-[#0d9488]"];
            const avatarBg = colors[review.name.length % colors.length];
            return (
              <div class="flex-none w-[85vw] sm:w-[calc((100%-32px)/2)] lg:w-[calc((100%-80px)/3)] snap-center flex flex-col text-left bg-white border border-stone-200/80 rounded-2xl shadow-sm hover:shadow-md transition-shadow duration-300 p-5">
                {/* Top Row: Author on left, Google G on right */}
                <div class="flex justify-between items-start w-full">
                  <div class="flex items-center gap-3">
                    {review.avatar ? (
                      <div class="w-10 h-10 rounded-full overflow-hidden shrink-0 border border-stone-100">
                        <img
                          src={review.avatar.startsWith('/') ? `${base}${review.avatar.slice(1)}` : review.avatar}
                          alt={review.name}
                          class="w-full h-full object-cover"
                          loading="lazy"
                          referrerpolicy="no-referrer"
                        />
                      </div>
                    ) : (
                      <div class={`w-10 h-10 rounded-full text-white flex items-center justify-center font-bold text-base shadow-sm shrink-0 uppercase ${review.avatarBg || avatarBg}`}>
                        {review.name.charAt(0)}
                      </div>
                    )}
                    <div class="flex flex-col">
                      <span class="text-stone-900 font-bold text-[15px] md:text-base leading-tight">{review.name}</span>
                      <span class="text-stone-400 text-xs mt-0.5">{review.date}</span>
                    </div>
                  </div>

                  {/* Google "G" Icon */}
                  <svg class="h-5 w-5 shrink-0" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                    <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4" />
                    <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853" />
                    <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.06H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.94l2.85-2.22.81-.63z" fill="#FBBC05" />
                    <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.06l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335" />
                  </svg>
                </div>

                {/* Stars & Verified Row */}
                <div class="flex items-center gap-1 mt-2.5">
                  <div class="flex gap-0.5">
                    {[...Array(review.rating)].map(() => (
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 fill-[#fbbc05]" viewBox="0 0 20 20">
                        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                      </svg>
                    ))}
                  </div>

                  {/* Blue Verified Badge */}
                  <svg class="h-4 w-4 shrink-0" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M12 22C17.5228 22 22 17.5228 22 12C22 6.47715 17.5228 2 12 2C6.47715 2 2 6.47715 2 12C2 17.5228 6.47715 22 12 22Z" fill="#3B82F6"/>
                    <path d="M7.5 12L10.5 15L16.5 9" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </div>

                {/* Review Text */}
                <p class="review-text text-stone-700 font-normal text-[14px] md:text-[15px] leading-relaxed tracking-normal font-sans line-clamp-4 grow mt-3">
                  {review.text}
                </p>

                {/* Read More Link */}
                {review.text.length > 180 && (
                  <span class="read-more-btn text-stone-400 text-sm font-medium hover:underline cursor-pointer select-none mt-3">Read more</span>
                )}
              </div>
            );
          })}
        </div>
      </div>
    </div>

    {/* Style component to hide scrollbars natively */}
    <style>
      .no-scrollbar::-webkit-scrollbar {
        display: none;
      }
      .no-scrollbar {
        -ms-overflow-style: none;  /* IE and Edge */
        scrollbar-width: none;  /* Firefox */
      }
    </style>

    {/* Client side navigation handling */}
    <script>
      document.addEventListener('astro:page-load', () => {
        // --- Transformation Carousel ---
        const transPrev = document.getElementById('carousel-prev');
        const transNext = document.getElementById('carousel-next');
        const transTrack = document.getElementById('transformation-carousel');

        let transInterval: any;

        function startTransAutoSlide() {
          stopTransAutoSlide();
          transInterval = setInterval(() => {
            if (!transTrack) return;
            const itemWidth = transTrack.firstElementChild?.clientWidth || 300;
            const gap = 24;
            const maxScroll = transTrack.scrollWidth - transTrack.clientWidth;

            if (transTrack.scrollLeft >= maxScroll - 10) {
              transTrack.scrollTo({ left: 0, behavior: 'smooth' });
            } else {
              transTrack.scrollBy({ left: itemWidth + gap, behavior: 'smooth' });
            }
          }, 4000);
        }

        function stopTransAutoSlide() {
          if (transInterval) clearInterval(transInterval);
        }

        if (transPrev && transNext && transTrack) {
          transPrev.addEventListener('click', () => {
            const itemWidth = transTrack.firstElementChild?.clientWidth || 300;
            const gap = 24;
            const maxScroll = transTrack.scrollWidth - transTrack.clientWidth;

            if (transTrack.scrollLeft <= 10) {
              transTrack.scrollTo({ left: maxScroll, behavior: 'smooth' });
            } else {
              transTrack.scrollBy({ left: -(itemWidth + 24), behavior: 'smooth' });
            }
            startTransAutoSlide();
          });

          transNext.addEventListener('click', () => {
            const itemWidth = transTrack.firstElementChild?.clientWidth || 300;
            const gap = 24;
            const maxScroll = transTrack.scrollWidth - transTrack.clientWidth;

            if (transTrack.scrollLeft >= maxScroll - 10) {
              transTrack.scrollTo({ left: 0, behavior: 'smooth' });
            } else {
              transTrack.scrollBy({ left: itemWidth + gap, behavior: 'smooth' });
            }
            startTransAutoSlide();
          });

          // Pause on hover
          transTrack.addEventListener('mouseenter', stopTransAutoSlide);
          transTrack.addEventListener('mouseleave', startTransAutoSlide);

          startTransAutoSlide();
        }

        // --- Reviews Carousel ---
        const revPrev = document.getElementById('reviews-prev');
        const revNext = document.getElementById('reviews-next');
        const revTrack = document.getElementById('reviews-carousel');

        let revInterval: any;

        function startRevAutoSlide() {
          stopRevAutoSlide();
          revInterval = setInterval(() => {
            if (!revTrack) return;
            const itemWidth = revTrack.firstElementChild?.clientWidth || 300;
            const gap = window.innerWidth >= 1024 ? 40 : 32;
            const maxScroll = revTrack.scrollWidth - revTrack.clientWidth;

            if (revTrack.scrollLeft >= maxScroll - 10) {
              revTrack.scrollTo({ left: 0, behavior: 'smooth' });
            } else {
              revTrack.scrollBy({ left: itemWidth + gap, behavior: 'smooth' });
            }
          }, 5000);
        }

        function stopRevAutoSlide() {
          if (revInterval) clearInterval(revInterval);
        }

        if (revPrev && revNext && revTrack) {
          revPrev.addEventListener('click', () => {
            const itemWidth = revTrack.firstElementChild?.clientWidth || 300;
            const gap = window.innerWidth >= 1024 ? 40 : 32;
            const maxScroll = revTrack.scrollWidth - revTrack.clientWidth;

            if (revTrack.scrollLeft <= 10) {
              revTrack.scrollTo({ left: maxScroll, behavior: 'smooth' });
            } else {
              revTrack.scrollBy({ left: -(itemWidth + gap), behavior: 'smooth' });
            }
            startRevAutoSlide();
          });

          revNext.addEventListener('click', () => {
            const itemWidth = revTrack.firstElementChild?.clientWidth || 300;
            const gap = window.innerWidth >= 1024 ? 40 : 32;
            const maxScroll = revTrack.scrollWidth - revTrack.clientWidth;

            if (revTrack.scrollLeft >= maxScroll - 10) {
              revTrack.scrollTo({ left: 0, behavior: 'smooth' });
            } else {
              revTrack.scrollBy({ left: itemWidth + gap, behavior: 'smooth' });
            }
            startRevAutoSlide();
          });

          // Pause on hover
          revTrack.addEventListener('mouseenter', stopRevAutoSlide);
          revTrack.addEventListener('mouseleave', startRevAutoSlide);

          startRevAutoSlide();
        }

        // --- Read More / Expand Handler ---
        const readMoreBtns = document.querySelectorAll('.read-more-btn');
        readMoreBtns.forEach(btn => {
          btn.addEventListener('click', (e) => {
            const btnEl = e.currentTarget as HTMLElement;
            const parent = btnEl.parentElement;
            if (parent) {
              const textEl = parent.querySelector('.review-text');
              if (textEl) {
                textEl.classList.remove('line-clamp-4');
                btnEl.style.display = 'none';
              }
            }
          });
        });
      });
    </script>
  </section>

  {/* SECTION 7: CONTACT & MAP - One Job Per Section */}
  <section class="py-16 lg:py-20 bg-stone-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="flex flex-col gap-6">
          <span class="text-xs font-bold uppercase tracking-widest text-teal-600 font-mono">Location & Hours</span>
          <h2 class="text-3xl sm:text-5xl font-extrabold text-stone-900">Visit Our Dental Clinic</h2>
          <p class="text-lg text-stone-600 leading-relaxed">
            One Smile Dental Care is strategically located to serve you with top-tier dental treatments. Our doors are open Tuesday through Sunday.
          </p>
          <div class="flex flex-col gap-4 text-stone-700 border-l-2 border-teal-500 pl-6 my-4">
            <div>
              <h4 class="font-bold text-stone-950">Clinic Address</h4>
              <p class="text-sm mt-1 font-semibold text-stone-800">
                5/437, near Dayal Paradise, Vikas Khand, Gomti Nagar,<br />
                Lucknow, Uttar Pradesh 226010
              </p>
            </div>
            <div>
              <h4 class="font-bold text-stone-950">Operating Hours</h4>
              <p class="text-sm mt-1">Tuesday - Saturday: 10:00AM - 02:00PM, 5:00PM - 08:00PM</p>
              <p class="text-sm">Sunday: 10:00AM - 01:00PM</p>
              <p class="text-sm text-red-500 font-semibold mt-0.5">Monday: Closed</p>
            </div>
          </div>
          <div class="flex flex-wrap gap-4">
            <a
              href="https://www.google.com/maps?cid=11247058903890459605&g_mp=CiVnb29nbGUubWFwcy5wbGFjZXMudjEuUGxhY2VzLkdldFBsYWNlEAMYASAF&hl=en&gl=US&source=embed"
              target="_blank"
              rel="noopener noreferrer"
              class="btn btn-primary text-white"
            >
              Get Directions
            </a>
            <a href="tel:+918400021200" class="btn btn-outline text-stone-800 hover:bg-stone-200">
              Call Clinic
            </a>
          </div>
        </div>

        {/* Map Embed or Static Anchor */}
        <div class="w-full aspect-[4/3] rounded-2xl overflow-hidden border border-stone-200 shadow-lg relative bg-stone-100">
          <iframe
            src="https://maps.google.com/maps?q=One%20Smile%20Dental%20Care,%205/437,%20near%20Dayal%20Paradise,%20Vikas%20Khand,%20Gomti%20Nagar,%20Lucknow&t=&z=16&ie=UTF8&iwloc=&output=embed"
            class="w-full h-full border-0 absolute inset-0"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Google Maps Location for One Smile Dental Care"
          ></iframe>
        </div>
      </div>
    </div>
  </section>
</Layout>

