---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allServices = await getCollection('services');
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const featuredServices = allServices
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 6);

const patientPhotos = [
  "/patients/patient1.jpg",
  "/patients/patient2.jpg",
  "/patients/patient3.jpg",
  "/patients/patient4.jpg",
  "/patients/patient5.jpg",
  "/patients/patient6.jpg",
  "/patients/patient7.jpg",
  "/patients/patient8.jpg",
  "/patients/patient9.jpg",
  "/patients/patient10.jpg",
].map(path => `${base}${path.replace(/^\//, '')}`);

const googleReviews = [
  {
    name: "Mukesh Kumar",
    rating: 5,
    text: "Dr. Radhika is amazing! The dental implant procedure was completely painless and the results are natural. Highly recommend One Smile Dental Care.",
    date: "1 day ago",
    avatar: "/patients/patient1.jpg"
  },
  {
    name: "Priya Sharma",
    rating: 5,
    text: "Best dental clinic in the area. Sterile environment, state-of-the-art tools, and very friendly staff. My child felt so comfortable during her preventive care cleaning.",
    date: "2 days ago",
    avatar: "/patients/patient7.jpg"
  },
  {
    name: "Marko Dorrestijn",
    rating: 5,
    text: "The 'Wellness' in their name aptly refers to the calm and positive atmosphere. I feel relaxed and a bit like new... am I actually looking forward to the next dentist visit?",
    date: "3 days ago",
    avatar: "/patients/patient6.jpg"
  },
  {
    name: "Rajesh Singh",
    rating: 5,
    text: "Got my clear aligners from here. Extremely satisfied with the treatment. The staff is polite, and the clinic is clean. Dr. Radhika explains everything very clearly.",
    date: "4 days ago",
    avatar: "/patients/patient3.jpg"
  },
  {
    name: "Shania Govani",
    rating: 5,
    text: "Most amazing dental practice I’ve been to! Very kind and friendly staff as well a highly qualified skilled dentists! Wouldn’t go anywhere else for my teeth! Absolutely love love the results, the dentists here won’t stop until you are 100% satisfied!",
    date: "5 days ago",
    avatar: null
  },
  {
    name: "Aditya Gupta",
    rating: 5,
    text: "Highly professional team. The laser teeth whitening treatment gave me immediate results. Dr. Radhika and her staff are dental experts who prioritize patient comfort.",
    date: "6 days ago",
    avatar: "/patients/patient5.jpg"
  },
  {
    name: "Sejal hulashia",
    rating: 5,
    text: "The best dental practice around with dentists that are able to tackle all issues. THROUGHLY enjoyed my experience here and will not be going anywhere else for my future dental needs! Cannot recommend them enough!",
    date: "1 week ago",
    avatar: "/patients/patient2.jpg"
  },
  {
    name: "Karan Malhotra",
    rating: 5,
    text: "Extremely clean and hygienic clinic. They follow strict sterilization protocols. Dr. Radhika fixed my chipped front tooth with bonding, and it's completely invisible now!",
    date: "2 weeks ago",
    avatar: "/patients/patient8.jpg"
  },
  {
    name: "Dr. Anjali Mehta",
    rating: 5,
    text: "As a fellow medical professional, I am highly impressed by their Class-B autoclave sterilization and clinical hygiene. Dr. Radhika is exceptionally skilled and gentle.",
    date: "3 weeks ago",
    avatar: "/patients/patient9.jpg"
  },
  {
    name: "Sneha Verma",
    rating: 5,
    text: "Excellent single-sitting root canal treatment. Fast, sterile, and totally pain-free. I had severe toothache, and it was relieved immediately.",
    date: "1 month ago",
    avatar: "/patients/patient4.jpg"
  }
];
---

<Layout title="One Smile Dental Care | Premier Dental Implants & Smile Makeovers">
  {/* SECTION 1: HERO - One Composition, Brand First, Full-bleed */}
  <section class="relative min-h-[90vh] flex items-end justify-center text-white overflow-hidden bg-stone-950 pb-6 sm:pb-10">
    {/* Full-bleed dominant background image */}
    <div class="absolute inset-0 z-0">
      <img 
        src={`${base}banners/banner.jpg`} 
        alt="Smiling patient showing beautiful white teeth" 
        class="w-full h-full object-cover object-center opacity-70 scale-105 animate-[zoomOut_20s_ease-out_forwards]"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-stone-950 via-stone-900/40 to-stone-950/20 z-10"></div>
    </div>

    {/* Hero content aligned left to prevent covering doctor/team faces on the right */}
    <div class="relative z-20 max-w-7xl w-full mx-auto px-4 sm:px-6 lg:px-8 text-left flex flex-col items-start gap-4">
      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-black tracking-wider leading-[1.1] text-white max-w-2xl animate-[fadeInUp_1s_ease_forwards_0.2s] opacity-0 fill-mode-forwards">
        YOUR BRIGHT & BEAUTIFUL<br />
        <span class="text-teal-400">SMILE</span><br />
        BEGINS HERE
      </h1>
      <div class="flex flex-wrap items-center justify-start gap-4 mt-2 animate-[fadeInUp_1s_ease_forwards_0.6s] opacity-0 fill-mode-forwards">
        <a href="https://wa.me/918400021200" target="_blank" rel="noopener noreferrer" class="btn btn-primary btn-lg text-base font-bold shadow-lg shadow-teal-500/20 hover:scale-105 transition-transform duration-300">
          Book Appointment
        </a>
        <a href={`${base}services`} class="btn btn-outline btn-lg text-white hover:bg-white hover:text-stone-950 border-white/60 hover:border-white transition-all duration-300">
          Explore Services
        </a>
      </div>
    </div>
  </section>

  {/* SECTION 2: SERVICES SHOWCASE - One Job Per Section */}
  <section class="py-24 bg-stone-50 border-b border-stone-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <h2 class="text-3xl sm:text-5xl font-extrabold text-stone-900 mb-4">Specialized Dental Care</h2>
        <p class="text-lg text-stone-600">
          We combine cutting-edge technology and gentle clinical practices to offer premium orthodontic and cosmetic solutions.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {featuredServices.map(service => (
          <div class="group relative flex flex-col justify-between overflow-hidden bg-white rounded-2xl border border-stone-200 transition-all duration-300 hover:shadow-xl hover:border-teal-500/20">
            <div>
              <div class="aspect-video w-full overflow-hidden bg-stone-100">
                <img 
                  src={service.data.image.startsWith('/') ? `${base}${service.data.image.slice(1)}` : service.data.image} 
                  alt={service.data.title} 
                  class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                  loading="lazy"
                />
              </div>
              <div class="p-6">
                <h3 class="text-xl font-bold text-stone-900 mb-2 group-hover:text-teal-600 transition-colors">
                  {service.data.title}
                </h3>
                <p class="text-sm text-stone-600 leading-relaxed line-clamp-3">
                  {service.data.summary}
                </p>
              </div>
            </div>
            <div class="p-6 pt-0">
              <a href={`${base}services/${service.id}`} class="inline-flex items-center gap-2 text-sm font-semibold text-teal-600 hover:text-teal-800 transition-colors group/link">
                Learn treatment details
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 transition-transform duration-200 group-hover/link:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
              </a>
            </div>
          </div>
        ))}
      </div>

      <div class="text-center mt-12">
        <a href={`${base}services`} class="btn btn-primary btn-outline font-semibold">
          View All 14 Services
        </a>
      </div>
    </div>
  </section>

  {/* SECTION 3: DR RADHIKA - One Job, Real Visual Anchor */}
  <section class="py-24 bg-stone-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
        <div class="lg:col-span-5 relative">
          <div class="aspect-[3/4] w-full rounded-2xl overflow-hidden bg-stone-200 shadow-2xl relative">
            <img 
              src={`${base}doctors/doctor-radhika-1.jpg`} 
              alt="Dr. Radhika, lead dentist at One Smile Dental Care" 
              class="w-full h-full object-cover"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-stone-900/60 via-transparent to-transparent"></div>
            <div class="absolute bottom-6 left-6 text-white z-10">
              <div class="text-lg font-bold">Dr. Radhika Rastogi</div>
              <div class="text-xs text-teal-400 font-semibold uppercase tracking-wider">Lead Surgeon & Smile Architect</div>
            </div>
          </div>
        </div>
        <div class="lg:col-span-7 flex flex-col gap-6">
          <span class="text-xs font-bold uppercase tracking-widest text-teal-600">Clinical Leadership</span>
          <h2 class="text-3xl sm:text-5xl font-extrabold text-stone-900">Dr. Radhika Rastogi</h2>
          <p class="text-lg text-stone-600 leading-relaxed">
            Led by Dr. Radhika Rastogi (senior resident from AIIMS & KGMC; MDS in Endodontics & Aesthetics), our team combines a deep passion for dental aesthetics with years of advanced surgical experience. We believe visiting the dentist should be sterile, pain-free, and customized to your goals.
          </p>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 mt-2">
            <div class="flex items-start gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-teal-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
              <div>
                <h4 class="font-bold text-stone-900">Class-A Sterilization</h4>
                <p class="text-sm text-stone-600">Strict hygiene protocols using autoclave technology for patient safety.</p>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-teal-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <div>
                <h4 class="font-bold text-stone-900">Pain-Free Techniques</h4>
                <p class="text-sm text-stone-600">Advanced anesthesia systems and rotary tools for comfortable procedures.</p>
              </div>
            </div>
          </div>
          <div class="mt-4">
            <a href={`${base}about`} class="btn btn-primary text-white">
              Learn About Dr. Radhika Rastogi
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* SECTION 4: PATIENT SMILE CAROUSEL - Premium Grid Carousel */}
  <section class="py-24 bg-stone-50 overflow-hidden border-b border-stone-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      
      {/* Carousel Header (Centered) */}
      <div class="text-center max-w-3xl mx-auto mb-12">
        <h2 class="text-3xl sm:text-5xl font-extrabold text-stone-900 mb-4">Patient Smile Transformations</h2>
        <p class="text-lg text-stone-600">
          View the real results of our cosmetic and orthodontic treatments, highlighting dental wellness and aesthetic excellence.
        </p>
      </div>

      {/* Carousel Container with Absolute Overlay Buttons */}
      <div class="relative w-full group/carousel">
        
        {/* Prev Button (Absolute Left Edge) */}
        <button id="carousel-prev" class="absolute -left-4 sm:left-4 top-1/2 -translate-y-1/2 btn btn-circle bg-white/80 backdrop-blur-md border-stone-200 text-stone-700 shadow-lg hover:bg-teal-600 hover:text-white hover:border-teal-600 transition-all duration-300 z-10" aria-label="Previous Slide">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 19l-7-7 7-7" />
          </svg>
        </button>

        {/* Next Button (Absolute Right Edge) */}
        <button id="carousel-next" class="absolute -right-4 sm:right-4 top-1/2 -translate-y-1/2 btn btn-circle bg-white/80 backdrop-blur-md border-stone-200 text-stone-700 shadow-lg hover:bg-teal-600 hover:text-white hover:border-teal-600 transition-all duration-300 z-10" aria-label="Next Slide">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" />
          </svg>
        </button>

        {/* Grid Track Carousel */}
        <div id="transformation-carousel" class="carousel w-full gap-6 py-4 scroll-smooth">
          {patientPhotos.map((photo, idx) => (
            <div id={`slide-${idx}`} class="carousel-item w-full sm:w-[calc(50%-12px)] md:w-[calc(33.333%-16px)] flex flex-col bg-white border border-stone-200 rounded-2xl overflow-hidden shadow-sm hover:shadow-md transition-all duration-300">
              <div class="aspect-[4/3] w-full overflow-hidden bg-stone-100">
                <img 
                  src={photo} 
                  alt={`One Smile patient transformation ${idx + 1}`} 
                  class="w-full h-full object-cover transition-transform duration-500 hover:scale-105" 
                  loading="lazy"
                />
              </div>
              <div class="p-4 bg-white border-t border-stone-100 flex items-center justify-between">
                <span class="text-sm font-bold text-stone-800">Smile Transformation {idx + 1}</span>
                <span class="text-xs font-semibold uppercase tracking-wider text-teal-600 bg-teal-50 px-2.5 py-1 rounded-full border border-teal-100/50">Successful</span>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>

    {/* Client side navigation handling */}
    <script>
      document.addEventListener('astro:page-load', () => {
        const prevBtn = document.getElementById('carousel-prev');
        const nextBtn = document.getElementById('carousel-next');
        const track = document.getElementById('transformation-carousel');
        
        if (prevBtn && nextBtn && track) {
          prevBtn.addEventListener('click', () => {
            const itemWidth = track.firstElementChild?.clientWidth || 300;
            track.scrollBy({ left: -(itemWidth + 24), behavior: 'smooth' });
          });
          
          nextBtn.addEventListener('click', () => {
            const itemWidth = track.firstElementChild?.clientWidth || 300;
            track.scrollBy({ left: itemWidth + 24, behavior: 'smooth' });
          });
        }
      });
    </script>
  </section>

  {/* SECTION 5: GOOGLE REVIEWS - Premium Google Reviews Carousel */}
  <section class="py-24 bg-[#faf8f5] relative overflow-hidden">
    {/* Decorative background shapes for smooth plaster/marble texture look */}
    <div class="absolute -top-[10%] -left-[10%] w-[45vw] aspect-square rounded-full bg-[#f3ece0] blur-[100px] opacity-60 pointer-events-none"></div>
    <div class="absolute -bottom-[10%] -right-[10%] w-[45vw] aspect-square rounded-full bg-[#f0e6d8] blur-[100px] opacity-60 pointer-events-none"></div>

    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto mb-20">
        <h2 class="text-3xl sm:text-5xl font-extrabold text-stone-900 mb-4 tracking-tight">Verified Google Reviews</h2>
        <p class="text-lg text-stone-700 font-medium">
          See what our patients say about their surgical and cosmetic experiences.
        </p>
      </div>

      <div class="relative w-full">
        {/* Navigation Buttons (visible on tablet/desktop, hidden on mobile) */}
        <button id="reviews-prev" class="hidden sm:flex absolute -left-4 lg:-left-16 top-1/2 -translate-y-1/2 btn btn-circle bg-transparent hover:bg-stone-900/5 border border-stone-800/10 text-stone-800 transition-all duration-300 z-20 items-center justify-center shadow-sm" aria-label="Previous Review">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
        </button>
        <button id="reviews-next" class="hidden sm:flex absolute -right-4 lg:-right-16 top-1/2 -translate-y-1/2 btn btn-circle bg-transparent hover:bg-stone-900/5 border border-stone-800/10 text-stone-800 transition-all duration-300 z-20 items-center justify-center shadow-sm" aria-label="Next Review">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </button>

        {/* Carousel Track */}
        <div id="reviews-carousel" class="flex gap-8 lg:gap-10 overflow-x-auto snap-x snap-mandatory scroll-smooth no-scrollbar pb-6 px-1">
          {googleReviews.map((review) => (
            <div class="flex-none w-[85vw] sm:w-[calc((100%-32px)/2)] lg:w-[calc((100%-80px)/3)] snap-center flex flex-col gap-6 text-left">
              {/* Stars & Google logo row */}
              <div class="flex justify-between items-center w-full">
                <div class="flex gap-0.5">
                  {[...Array(review.rating)].map(() => (
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 fill-[#9c9684]" viewBox="0 0 20 20">
                      <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                    </svg>
                  ))}
                </div>
                <svg class="h-6 w-6 shrink-0" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                  <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4" />
                  <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853" />
                  <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.06H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.94l2.85-2.22.81-.63z" fill="#FBBC05" />
                  <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.06l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335" />
                </svg>
              </div>

              {/* Review text */}
              <p class="text-[#2d2b27] font-normal text-base md:text-[17px] leading-relaxed tracking-normal font-sans grow">
                {review.text}
              </p>

              {/* Author Info */}
              <div class="flex items-center gap-4 mt-auto pt-4">
                {review.avatar ? (
                  <div class="relative w-12 h-12 rounded-full overflow-hidden shrink-0 border border-stone-400/10">
                    <img 
                      src={review.avatar.startsWith('/') ? `${base}${review.avatar.slice(1)}` : review.avatar} 
                      alt={review.name} 
                      class="w-full h-full object-cover"
                      loading="lazy"
                    />
                    {review.name === "Marko Dorrestijn" && (
                      <div class="absolute bottom-0 right-0 bg-[#faf8f5] rounded-full p-0.5 shadow-sm border border-stone-400/10">
                        <div class="w-3.5 h-3.5 bg-orange-500 rounded-full flex items-center justify-center text-white">
                          <svg viewBox="0 0 24 24" class="w-2.5 h-2.5 fill-current" xmlns="http://www.w3.org/2000/svg">
                            <path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/>
                          </svg>
                        </div>
                      </div>
                    )}
                  </div>
                ) : (
                  <div class="w-12 h-12 rounded-full bg-[#8ba5e2] text-white flex items-center justify-center font-bold text-lg shadow-sm shrink-0">
                    <svg class="h-7 w-7 text-white fill-current opacity-85" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                      <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z" />
                    </svg>
                  </div>
                )}
                <div class="flex flex-col">
                  <span class="text-stone-900 font-bold text-[15px] md:text-base leading-tight">{review.name}</span>
                  <span class="text-stone-700 text-sm mt-0.5">{review.date}</span>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>

    {/* Style component to hide scrollbars natively */}
    <style>
      .no-scrollbar::-webkit-scrollbar {
        display: none;
      }
      .no-scrollbar {
        -ms-overflow-style: none;  /* IE and Edge */
        scrollbar-width: none;  /* Firefox */
      }
    </style>

    {/* Client side navigation handling */}
    <script>
      document.addEventListener('astro:page-load', () => {
        // --- Transformation Carousel ---
        const transPrev = document.getElementById('carousel-prev');
        const transNext = document.getElementById('carousel-next');
        const transTrack = document.getElementById('transformation-carousel');
        
        let transInterval: any;
        
        function startTransAutoSlide() {
          stopTransAutoSlide();
          transInterval = setInterval(() => {
            if (!transTrack) return;
            const itemWidth = transTrack.firstElementChild?.clientWidth || 300;
            const gap = 24;
            const maxScroll = transTrack.scrollWidth - transTrack.clientWidth;
            
            if (transTrack.scrollLeft >= maxScroll - 10) {
              transTrack.scrollTo({ left: 0, behavior: 'smooth' });
            } else {
              transTrack.scrollBy({ left: itemWidth + gap, behavior: 'smooth' });
            }
          }, 4000);
        }
        
        function stopTransAutoSlide() {
          if (transInterval) clearInterval(transInterval);
        }
        
        if (transPrev && transNext && transTrack) {
          transPrev.addEventListener('click', () => {
            const itemWidth = transTrack.firstElementChild?.clientWidth || 300;
            const gap = 24;
            const maxScroll = transTrack.scrollWidth - transTrack.clientWidth;
            
            if (transTrack.scrollLeft <= 10) {
              transTrack.scrollTo({ left: maxScroll, behavior: 'smooth' });
            } else {
              transTrack.scrollBy({ left: -(itemWidth + 24), behavior: 'smooth' });
            }
            startTransAutoSlide();
          });
          
          transNext.addEventListener('click', () => {
            const itemWidth = transTrack.firstElementChild?.clientWidth || 300;
            const gap = 24;
            const maxScroll = transTrack.scrollWidth - transTrack.clientWidth;
            
            if (transTrack.scrollLeft >= maxScroll - 10) {
              transTrack.scrollTo({ left: 0, behavior: 'smooth' });
            } else {
              transTrack.scrollBy({ left: itemWidth + gap, behavior: 'smooth' });
            }
            startTransAutoSlide();
          });
          
          // Pause on hover
          transTrack.addEventListener('mouseenter', stopTransAutoSlide);
          transTrack.addEventListener('mouseleave', startTransAutoSlide);
          
          startTransAutoSlide();
        }

        // --- Reviews Carousel ---
        const revPrev = document.getElementById('reviews-prev');
        const revNext = document.getElementById('reviews-next');
        const revTrack = document.getElementById('reviews-carousel');
        
        let revInterval: any;
        
        function startRevAutoSlide() {
          stopRevAutoSlide();
          revInterval = setInterval(() => {
            if (!revTrack) return;
            const itemWidth = revTrack.firstElementChild?.clientWidth || 300;
            const gap = window.innerWidth >= 1024 ? 40 : 32;
            const maxScroll = revTrack.scrollWidth - revTrack.clientWidth;
            
            if (revTrack.scrollLeft >= maxScroll - 10) {
              revTrack.scrollTo({ left: 0, behavior: 'smooth' });
            } else {
              revTrack.scrollBy({ left: itemWidth + gap, behavior: 'smooth' });
            }
          }, 5000);
        }
        
        function stopRevAutoSlide() {
          if (revInterval) clearInterval(revInterval);
        }
        
        if (revPrev && revNext && revTrack) {
          revPrev.addEventListener('click', () => {
            const itemWidth = revTrack.firstElementChild?.clientWidth || 300;
            const gap = window.innerWidth >= 1024 ? 40 : 32;
            const maxScroll = revTrack.scrollWidth - revTrack.clientWidth;
            
            if (revTrack.scrollLeft <= 10) {
              revTrack.scrollTo({ left: maxScroll, behavior: 'smooth' });
            } else {
              revTrack.scrollBy({ left: -(itemWidth + gap), behavior: 'smooth' });
            }
            startRevAutoSlide();
          });
          
          revNext.addEventListener('click', () => {
            const itemWidth = revTrack.firstElementChild?.clientWidth || 300;
            const gap = window.innerWidth >= 1024 ? 40 : 32;
            const maxScroll = revTrack.scrollWidth - revTrack.clientWidth;
            
            if (revTrack.scrollLeft >= maxScroll - 10) {
              revTrack.scrollTo({ left: 0, behavior: 'smooth' });
            } else {
              revTrack.scrollBy({ left: itemWidth + gap, behavior: 'smooth' });
            }
            startRevAutoSlide();
          });
          
          // Pause on hover
          revTrack.addEventListener('mouseenter', stopRevAutoSlide);
          revTrack.addEventListener('mouseleave', startRevAutoSlide);
          
          startRevAutoSlide();
        }
      });
    </script>
  </section>

